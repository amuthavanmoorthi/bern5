    "scoringFormulas": {
        "highPerformance": {
            "condition": "EEI <= 0.8",
            "formula": "50 + 40 * (0.8 - EEI) / 0.3",
            "description": "Score for high-performance buildings (EEI ≤ 0.8)"
        },
        "standard": {
            "condition": "EEI > 0.8",
            "formula": "50 * (2.0 - EEI) / 1.2",
            "description": "Score for standard buildings (EEI > 0.8)"
        }
    },
    "euiScaleFormulas": {
        "EUIn": "UR × (0.5 × (AEUI + LEUI + EtEUI + HpEUI) + EEUI)",
        "EUIg": "UR × (0.8 × (AEUI + LEUI + EtEUI + HpEUI) + EEUI)",
        "EUIm": "UR × (1.0 × (AEUI + LEUI + EtEUI + HpEUI) + EEUI)",
        "EUImax": "UR × (2.0 × (AEUI + LEUI + EtEUI + HpEUI) + EEUI)"
    },
    "weightFormulas": {
        "withoutDHW": {
            "a": "AEUI / (EtEUI + AEUI + LEUI)",
            "b": "LEUI / (EtEUI + AEUI + LEUI)",
            "c": "EtEUI / (EtEUI + AEUI + LEUI)"
        },
        "withDHW": {
            "a": "AEUI / (AEUI + LEUI + EtEUI + HpEUI)",
            "b": "LEUI / (AEUI + LEUI + EtEUI + HpEUI)",
            "c": "EtEUI / (AEUI + LEUI + EtEUI + HpEUI)",
            "d": "HpEUI / (AEUI + LEUI + EtEUI + HpEUI)"
        }
    }
